# SPA fallback for React Router on cPanel / Apache / LiteSpeed
# Fixes 404 when refreshing or opening /about-us, /contact, /services, etc.

# Prevent MultiViews from mapping /about-us to /about-us.html
<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files or directories (assets, api folder, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send all other requests to index.html (SPA handles the route)
  RewriteRule ^ /index.html [L]
</IfModule>

# Fallback when mod_rewrite is disabled (e.g. AllowOverride None):
# serve index.html for 404s so the SPA still loads and the URL stays (e.g. /about-us).
# React Router will then show the correct page.
ErrorDocument 404 /index.html
