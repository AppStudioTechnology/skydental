# SPA fallback: serve index.html for all routes so client-side routing works
# (fixes 404 on refresh or direct open of /contact, /about-us, /services, etc.)
# Required for React Router on Apache / LiteSpeed. If 404 persists, ask host to enable AllowOverride or use server config (see DEPLOY-CPANEL-STEPS.md).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for index.html, do nothing
  RewriteRule ^index\.html$ - [L]

  # If the request is for a real file or directory, do nothing
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise send to index.html (React Router will handle the path)
  RewriteRule ^ /index.html [L]
</IfModule>

# If rewrites above are ignored (e.g. beta/cPanel), server will 404 for /contact etc.
# 404.html redirects to /?redirect=/path; the app then navigates to the clean URL.
ErrorDocument 404 /404.html
